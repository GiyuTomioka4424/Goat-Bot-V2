const fs = require("fs-extra");
const path = require("path");

const BANK_DIR = path.join(process.cwd(), "cache");
const BANK_FILE = path.join(BANK_DIR, "bankData.json");
const PRISON_FILE = path.join(process.cwd(), "prisonData.json"); // PNP Sync

module.exports = {
    config: {
        name: "bank",
        version: "13.3",
        author: "Gab Yu | Shikaki",
        countDown: 5,
        role: 0,
        category: "economy"
    },

    onStart: async function ({ message, args, event, usersData, api }) {
        const { senderID } = event;
        const now = Date.now();

        // --- 🚨 MACKY PNP RESTRICTION GUARD ---
        if (fs.existsSync(PRISON_FILE)) {
            const prisonList = fs.readJsonSync(PRISON_FILE);
            if (prisonList[senderID] && now < prisonList[senderID].releaseAt) {
                return message.reply(
                    `╔════════════════════╗\n` +
                    `   🚨 𝗠𝗔𝗖𝗞𝗬 𝗣𝗡𝗣 𝗥𝗘𝗦𝗧𝗥𝗜𝗖𝗧𝗜𝗢𝗡\n` +
                    `╚════════════════════╝\n` +
                    `  ➤ 𝖲𝗍𝖺𝗍𝗎𝗌: 𝗔𝗖𝗖𝗘𝗦𝗦 𝗗𝗘𝗡𝗜𝗘𝗗\n` +
                    `  ➤ 𝖱𝖾𝖺𝗌𝗈𝗇: 𝖠𝖼𝗍𝗂𝗏𝖾 𝖶𝖺𝗋𝗋𝖺𝗇𝗍\n` +
                    `────────────────────\n` +
                    ` ⚖️ 𝖡𝖺𝗇𝗄𝗂𝗇𝗀 𝗉𝗋𝗂𝗏𝗂𝗅𝖾𝗀𝖾𝗌 𝗌𝖾𝗂𝗓𝖾𝖽.`
                );
            }
        }

        if (!fs.existsSync(BANK_DIR)) fs.mkdirSync(BANK_DIR, { recursive: true });
        if (!fs.existsSync(BANK_FILE)) fs.writeJsonSync(BANK_FILE, {});

        const bankData = fs.readJsonSync(BANK_FILE);
        if (!bankData[senderID]) {
            bankData[senderID] = { bank: 0, loan: 0, loanPayed: true, lastInterestClaimed: now };
        }

        const user = bankData[senderID];
        const userData = await usersData.get(senderID);
        const userMoney = userData.money || 0;
        const formatNum = (num) => (num || 0).toLocaleString();

        const design = (title, body) =>
            `╔════════════════════╗\n` +
            `       🏦  𝗠𝗔𝗖𝗞𝗬 𝗕𝗔𝗡𝗞\n` +
            `╚════════════════════╝\n` +
            `  ➤ 𝖲𝗍𝖺𝗍𝗎𝗌: ${title}\n` +
            `────────────────────\n` +
            `${body}\n` +
            `────────────────────\n` +
            ` ⚖️ 𝖠𝗅𝗅 𝗍𝗋𝖺𝗇𝗌𝖺𝖼𝗍𝗂𝗈𝗇𝗌 𝖺𝗋𝖾 𝗅𝗈𝗀𝗀𝖾𝖽.`;

        const act = args[0]?.toLowerCase();
        const val = args[1];

        // --- BALANCE ---
        if (!act || act === "bal") {
            const msg = ` 👤 ${await usersData.getName(senderID)}\n 💵 Wallet: $${formatNum(userMoney)}\n 💳 Vault: $${formatNum(user.bank)}\n 📉 Debt: $${formatNum(user.loan)}`;
            return message.reply(design("ACCOUNT INFO", msg));
        }

        // --- DEPOSIT ---
        if (act === "dep" || act === "deposit") {
            const amt = val === "all" ? userMoney : parseInt(val);
            if (!amt || amt <= 0 || userMoney < amt) return message.reply("❌ Invalid amount.");

            const tax = Math.floor(amt * 0.10);
            user.bank += (amt - tax);
            await usersData.set(senderID, { money: userMoney - amt });
            fs.writeJsonSync(BANK_FILE, bankData);
            return message.reply(design("DEPOSIT SUCCESS", `✅ Credited: $${formatNum(amt - tax)}\n⚖️ Tax (10%): -$${formatNum(tax)}`));
        }

        // --- WITHDRAW ---
        if (act === "wd" || act === "withdraw") {
            const amt = val === "all" ? user.bank : parseInt(val);
            if (!amt || amt <= 0 || user.bank < amt) return message.reply("❌ Insufficient vault funds.");

            user.bank -= amt;
            await usersData.set(senderID, { money: userMoney + amt });
            fs.writeJsonSync(BANK_FILE, bankData);
            return message.reply(design("WITHDRAWAL", `💸 $${formatNum(amt)} moved to Wallet.`));
        }

        // --- LOAN & PAYLOAN (Stayed same as v13.2) ---
        if (act === "loan") {
            if (user.loan > 0) return message.reply("❌ Pay your existing loan first!");
            const amt = parseInt(val);
            if (!amt || amt <= 0 || amt > 100000000) return message.reply("❌ Max loan is $100M.");
            user.loan = Math.floor(amt * 1.10);
            user.bank += amt;
            fs.writeJsonSync(BANK_FILE, bankData);
            return message.reply(design("LOAN APPROVED", `💵 Added: $${formatNum(amt)}\n📉 Debt: $${formatNum(user.loan)}`));
        }

        if (act === "pay") {
            const amt = val === "all" ? Math.min(userMoney, user.loan) : parseInt(val);
            if (!amt || amt <= 0 || userMoney < amt) return message.reply("❌ Invalid payment.");
            user.loan -= amt;
            await usersData.set(senderID, { money: userMoney - amt });
            fs.writeJsonSync(BANK_FILE, bankData);
            return message.reply(design("DEBT REDUCED", `💸 Paid: $${formatNum(amt)}\n📉 Remaining: $${formatNum(user.loan)}`));
        }

        return message.reply("❓ Usage: `!bank [dep/wd/loan/pay/bal]`");
    }
};
